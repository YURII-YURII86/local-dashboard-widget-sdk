{
  "id": "service-table",
  "title": "Service Table",
  "version": "0.1.0",
  "status": "lab",
  "source": {
    "kind": "local-json",
    "path": "services.items",
    "refreshMs": 10000
  },
  "renderer": {
    "kind": "table",
    "columns": [
      {"key": "name", "label": "Service"},
      {"key": "state", "label": "State"}
    ]
  },
  "layout": {"minW": 2, "minH": 1, "defaultW": 3, "defaultH": 2},
  "tags": ["system", "lab"]
}
