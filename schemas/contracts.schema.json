{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://example.com/schemas/local-dashboard-widget-sdk.contracts.v1.schema.json",
  "title": "Local Dashboard Widget SDK Contracts",
  "description": "Widget manifest and preset contracts for local dashboard/kiosk panels.",
  "oneOf": [
    {
      "$ref": "#/$defs/widget"
    },
    {
      "$ref": "#/$defs/preset"
    }
  ],
  "$defs": {
    "widget": {
      "type": "object",
      "additionalProperties": true,
      "required": [
        "id",
        "title",
        "version",
        "status",
        "source",
        "renderer",
        "layout"
      ],
      "properties": {
        "id": {
          "type": "string",
          "minLength": 1,
          "pattern": "^[a-z][a-z0-9-]{1,62}$"
        },
        "title": {
          "type": "string",
          "minLength": 1
        },
        "version": {
          "type": "string",
          "minLength": 1,
          "pattern": "^\\d+\\.\\d+\\.\\d+([-+][A-Za-z0-9.-]+)?$"
        },
        "status": {
          "type": "string",
          "minLength": 1,
          "enum": [
            "deprecated",
            "draft",
            "lab",
            "production"
          ]
        },
        "source": {
          "$ref": "#/$defs/source"
        },
        "renderer": {
          "$ref": "#/$defs/renderer"
        },
        "layout": {
          "$ref": "#/$defs/layout"
        },
        "tags": {
          "type": "array",
          "items": {
            "type": "string",
            "minLength": 1,
            "pattern": "^[a-z][a-z0-9-]{1,62}$"
          }
        }
      }
    },
    "preset": {
      "type": "object",
      "additionalProperties": true,
      "required": [
        "id",
        "title",
        "renderer"
      ],
      "properties": {
        "id": {
          "type": "string",
          "minLength": 1,
          "pattern": "^[a-z][a-z0-9-]{1,62}$"
        },
        "title": {
          "type": "string",
          "minLength": 1
        },
        "kind": {
          "const": "preset"
        },
        "renderer": {
          "type": "string",
          "minLength": 1,
          "enum": [
            "custom",
            "gauge",
            "log-timeline",
            "stat",
            "status-history",
            "table",
            "timeseries"
          ]
        },
        "layout": {
          "$ref": "#/$defs/layout"
        },
        "defaults": {
          "type": "object"
        }
      }
    },
    "source": {
      "type": "object",
      "additionalProperties": true,
      "required": [
        "kind"
      ],
      "properties": {
        "kind": {
          "type": "string",
          "minLength": 1,
          "enum": [
            "computed",
            "custom",
            "http-json",
            "local-json",
            "static"
          ]
        },
        "path": {
          "type": "string",
          "minLength": 1
        },
        "url": {
          "type": "string",
          "minLength": 1
        },
        "refreshMs": {
          "type": "integer",
          "minimum": 250
        }
      },
      "allOf": [
        {
          "if": {
            "properties": {
              "kind": {
                "const": "local-json"
              }
            }
          },
          "then": {
            "required": [
              "path"
            ]
          }
        },
        {
          "if": {
            "properties": {
              "kind": {
                "const": "computed"
              }
            }
          },
          "then": {
            "required": [
              "path"
            ]
          }
        },
        {
          "if": {
            "properties": {
              "kind": {
                "const": "http-json"
              }
            }
          },
          "then": {
            "required": [
              "path",
              "url"
            ]
          }
        }
      ]
    },
    "renderer": {
      "type": "object",
      "additionalProperties": true,
      "required": [
        "kind"
      ],
      "properties": {
        "kind": {
          "type": "string",
          "minLength": 1,
          "enum": [
            "custom",
            "gauge",
            "log-timeline",
            "stat",
            "status-history",
            "table",
            "timeseries"
          ]
        },
        "valuePath": {
          "type": "string",
          "minLength": 1
        },
        "unit": {
          "type": "string"
        },
        "thresholds": {
          "type": "array",
          "items": {
            "type": "object",
            "additionalProperties": false,
            "required": [
              "level"
            ],
            "properties": {
              "level": {
                "type": "string",
                "minLength": 1,
                "enum": [
                  "bad",
                  "info",
                  "ok",
                  "warn"
                ]
              },
              "gte": {
                "type": "number"
              },
              "lte": {
                "type": "number"
              },
              "label": {
                "type": "string",
                "minLength": 1
              }
            },
            "anyOf": [
              {
                "required": [
                  "gte"
                ]
              },
              {
                "required": [
                  "lte"
                ]
              }
            ]
          }
        },
        "columns": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "object",
            "additionalProperties": false,
            "required": [
              "key",
              "label"
            ],
            "properties": {
              "key": {
                "type": "string",
                "minLength": 1
              },
              "label": {
                "type": "string",
                "minLength": 1
              }
            }
          }
        },
        "seriesPath": {
          "type": "string",
          "minLength": 1
        },
        "xPath": {
          "type": "string",
          "minLength": 1
        },
        "yPath": {
          "type": "string",
          "minLength": 1
        },
        "itemsPath": {
          "type": "string",
          "minLength": 1
        },
        "component": {
          "type": "string",
          "minLength": 1
        }
      },
      "allOf": [
        {
          "if": {
            "properties": {
              "kind": {
                "enum": [
                  "stat",
                  "gauge"
                ]
              }
            }
          },
          "then": {
            "required": [
              "valuePath"
            ]
          }
        },
        {
          "if": {
            "properties": {
              "kind": {
                "const": "table"
              }
            }
          },
          "then": {
            "required": [
              "columns"
            ]
          }
        },
        {
          "if": {
            "properties": {
              "kind": {
                "const": "timeseries"
              }
            }
          },
          "then": {
            "required": [
              "seriesPath",
              "xPath",
              "yPath"
            ]
          }
        },
        {
          "if": {
            "properties": {
              "kind": {
                "enum": [
                  "log-timeline",
                  "status-history"
                ]
              }
            }
          },
          "then": {
            "required": [
              "itemsPath"
            ]
          }
        },
        {
          "if": {
            "properties": {
              "kind": {
                "const": "custom"
              }
            }
          },
          "then": {
            "required": [
              "component"
            ]
          }
        }
      ]
    },
    "layout": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "minW",
        "minH",
        "defaultW",
        "defaultH"
      ],
      "properties": {
        "minW": {
          "type": "integer",
          "minimum": 1
        },
        "minH": {
          "type": "integer",
          "minimum": 1
        },
        "defaultW": {
          "type": "integer",
          "minimum": 1
        },
        "defaultH": {
          "type": "integer",
          "minimum": 1
        }
      }
    },
    "threshold": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "level"
      ],
      "properties": {
        "level": {
          "type": "string",
          "minLength": 1,
          "enum": [
            "bad",
            "info",
            "ok",
            "warn"
          ]
        },
        "gte": {
          "type": "number"
        },
        "lte": {
          "type": "number"
        },
        "label": {
          "type": "string",
          "minLength": 1
        }
      },
      "anyOf": [
        {
          "required": [
            "gte"
          ]
        },
        {
          "required": [
            "lte"
          ]
        }
      ]
    }
  }
}
